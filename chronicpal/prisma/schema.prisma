// This is your Prisma schema file.
// Run `npx prisma generate` after any changes.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TreatmentType {
  INFUSION
  MEDICATION
  CLINIC_VISIT
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

enum PurineLevel {
  LOW
  MEDIUM
  HIGH
}

enum LinkStatus {
  PENDING
  ACTIVE
  REVOKED
}

enum UserRole {
  PATIENT
  CAREGIVER
  ADVISOR
}

model User {
  id             String           @id @default(cuid())
  email          String           @unique
  passwordHash   String
  role           UserRole         @default(PATIENT)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  treatments     TreatmentEntry[]
  labs           LabResult[]
  symptoms       SymptomEntry[]
  dietEntries    DietEntry[]
  caregiverLinks CaregiverLink[]  @relation("CaregiverLinks")
  patientLinks   CaregiverLink[]  @relation("PatientLinks")
}

model LabResult {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date          DateTime
  uricAcidLevel Float    // mg/dL; required for lab entries
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId, date])
}

model SymptomEntry {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime
  symptomType String
  severity    Int      // 1–10
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, date])
}

model TreatmentEntry {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  date          DateTime
  type          TreatmentType
  uricAcidLevel Float?        // mg/dL; optional — not every session includes a lab draw
  painScore     Int?          // 0–10; optional
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([userId, date])
}

model DietEntry {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  meal        String
  mealType    MealType
  purineLevel PurineLevel
  riskScore   Float?
  aiAnalysis  String?     @db.Text
  date        DateTime
  createdAt   DateTime    @default(now())

  @@index([userId, date])
}

model CaregiverLink {
  id          String     @id @default(cuid())
  caregiverId String
  caregiver   User       @relation("CaregiverLinks", fields: [caregiverId], references: [id])
  patientId   String
  patient     User       @relation("PatientLinks", fields: [patientId], references: [id])
  status      LinkStatus @default(PENDING)
  createdAt   DateTime   @default(now())

  @@unique([caregiverId, patientId])
}
