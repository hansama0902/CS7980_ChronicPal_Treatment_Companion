generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model CaregiverLink {
  id          String     @id @default(uuid())
  caregiverId String
  patientId   String
  status      LinkStatus @default(PENDING)
  createdAt   DateTime   @default(now())
  expiresAt   DateTime?
  caregiver   User       @relation("CaregiverLink_caregiverIdToUser", fields: [caregiverId], references: [id])
  patient     User       @relation("CaregiverLink_patientIdToUser", fields: [patientId], references: [id])

  @@unique([caregiverId, patientId])
}

model DietEntry {
  id          String      @id @default(uuid())
  userId      String
  meal        String
  mealType    MealType
  purineLevel PurineLevel
  riskScore   Float?
  aiAnalysis  String?
  date        DateTime
  createdAt   DateTime    @default(now())
  deletedAt   DateTime?
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model LabResult {
  id            String   @id @default(uuid())
  userId        String
  date          DateTime
  uricAcidLevel Float
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model SymptomEntry {
  id          String   @id @default(uuid())
  userId      String
  date        DateTime
  symptomType String
  severity    Int
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model TreatmentEntry {
  id            String        @id @default(uuid())
  userId        String
  date          DateTime
  type          TreatmentType
  uricAcidLevel Float?
  painScore     Int?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model User {
  id             String           @id @default(uuid())
  email          String           @unique
  passwordHash   String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  role           UserRole         @default(PATIENT)
  caregiverLinks CaregiverLink[]  @relation("CaregiverLink_caregiverIdToUser")
  patientLinks   CaregiverLink[]  @relation("CaregiverLink_patientIdToUser")
  dietEntries    DietEntry[]
  labResults     LabResult[]
  symptomEntries SymptomEntry[]
  treatments     TreatmentEntry[]
}

enum LinkStatus {
  PENDING
  ACTIVE
  REVOKED
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

enum PurineLevel {
  LOW
  MEDIUM
  HIGH
}

enum TreatmentType {
  INFUSION
  MEDICATION
  CLINIC_VISIT
}

enum UserRole {
  PATIENT
  CAREGIVER
}
